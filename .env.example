# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: The backend API URL
# For localhost: http://localhost:3001
# For production: https://your-deployed-backend.com (without trailing slash)
# If empty, uses same domain as frontend
VITE_API_URL=""

# SERVER PORT: Port for the backend server
PORT=3001

# JWT_SECRET: Secret key for JWT token signing
# Change this in production!
JWT_SECRET="super-secret-key-for-dev"

# NODE_ENV: Environment mode
# Values: development, production
NODE_ENV="development"

# DATABASE Path
DB_PATH="./database.sqlite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

